<Window x:Class="TOSAi.TeacherApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录 TOS AI"
        Width="430"
        Height="420"
        MinWidth="430"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Style="{StaticResource Card}" Margin="28">
        <StackPanel>
            <TextBlock Text="TOS AI"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextMainBrush}" />
            <TextBlock Text="请使用平台账号登录"
                       Margin="0,6,0,22"
                       Foreground="{StaticResource TextMutedBrush}" />

            <TextBlock Text="角色" FontWeight="SemiBold" />
            <ComboBox x:Name="RoleComboBox" Margin="0,8,0,16" MinHeight="34" SelectionChanged="RoleComboBox_SelectionChanged">
                <ComboBoxItem Content="教师端" Tag="Teacher" />
                <ComboBoxItem Content="学生端" Tag="Student" />
                <ComboBoxItem Content="家长端" Tag="Parent" />
            </ComboBox>

            <TextBlock Text="账号" FontWeight="SemiBold" />
            <TextBox x:Name="UsernameTextBox" Margin="0,8,0,16" MinHeight="34" />

            <TextBlock Text="密码" FontWeight="SemiBold" />
            <PasswordBox x:Name="PasswordBox" Margin="0,8,0,18" MinHeight="34" KeyDown="PasswordBox_KeyDown" />

            <Button x:Name="LoginButton"
                    Content="登录"
                    Style="{StaticResource PrimaryButton}"
                    Click="LoginButton_Click" />
            <TextBlock x:Name="StatusText"
                       Margin="0,14,0,0"
                       Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap" />

            <Border Background="{StaticResource SoftSurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,18,0,0">
                <TextBlock Text="演示账号：teacher / teacher123，student / student123，parent / parent123。"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextMainBrush}" />
            </Border>
        </StackPanel>
    </Border>
</Window>
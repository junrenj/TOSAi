<Window x:Class="TOSAi.TeacherApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TOS AI 学习平台"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="20,22,20,18">
                    <TextBlock Text="TOS AI"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMainBrush}" />
                    <TextBlock Text="多端学习数据平台"
                               Margin="0,4,0,14"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="当前端" FontWeight="SemiBold" />
                    <ComboBox x:Name="RoleComboBox"
                              Margin="0,8,0,0"
                              MinHeight="34"
                              SelectionChanged="RoleComboBox_SelectionChanged">
                        <ComboBoxItem Content="教师端" Tag="Teacher" />
                        <ComboBoxItem Content="学生端" Tag="Student" />
                        <ComboBoxItem Content="家长端" Tag="Parent" />
                    </ComboBox>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,18">
                    <RadioButton Content="系统设置"
                                 GroupName="MainNavigation"
                                 Style="{StaticResource NavRadioButton}"
                                 Tag="settings"
                                 Checked="NavigationButton_Checked" />
                </StackPanel>

                <StackPanel x:Name="NavigationPanel" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="92" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource AppBackgroundBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="28,18">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Content="刷新当前页"
                            Style="{StaticResource SecondaryButton}"
                            Click="RefreshPageButton_Click" />
                    <StackPanel>
                        <TextBlock x:Name="PageTitleText"
                                   Text="教师端"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMainBrush}" />
                        <TextBlock x:Name="PageSubtitleText"
                                   Text="统一从服务器读取数据，根据角色展示不同权限范围。"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <ContentControl x:Name="MainContentHost"
                            Grid.Row="1"
                            Margin="28" />
        </Grid>
    </Grid>
</Window>

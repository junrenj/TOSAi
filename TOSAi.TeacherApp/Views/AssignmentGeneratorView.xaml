<UserControl x:Class="TOSAi.TeacherApp.Views.AssignmentGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="880">
    <TabControl>
        <TabItem Header="生成作业">
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="第一步：选择作业范围" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="作业主题" FontWeight="SemiBold" />
                                <ListBox x:Name="TopicListBox" SelectionMode="Multiple" MinHeight="108" Margin="0,8,0,16" />
                                <TextBlock Text="考察主要方向" FontWeight="SemiBold" />
                                <ListBox x:Name="DirectionListBox" SelectionMode="Multiple" MinHeight="108" Margin="0,8,0,16" />
                                <TextBlock Text="情景分类" FontWeight="SemiBold" />
                                <ListBox x:Name="ScenarioListBox" SelectionMode="Multiple" MinHeight="108" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="第二步：设置卷面结构" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="整张卷子的难度系数" FontWeight="SemiBold" />
                                <ComboBox x:Name="DifficultyComboBox" MinHeight="34" Margin="0,8,0,16" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="选择题数量" FontWeight="SemiBold" />
                                        <TextBox x:Name="ChoiceCountTextBox" Text="8" MinHeight="34" Margin="0,8,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="大题数量" FontWeight="SemiBold" />
                                        <TextBox x:Name="EssayCountTextBox" Text="3" MinHeight="34" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Grid>
                                <Button Content="生成作业" Margin="0,18,0,0" Style="{StaticResource PrimaryButton}" Click="GenerateButton_Click" />
                                <Button Content="下载 HTML" Margin="0,10,0,0" Style="{StaticResource SecondaryButton}" Click="DownloadButton_Click" />
                                <TextBlock x:Name="StatusText" Margin="0,14,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border x:Name="ReplacePanel" Style="{StaticResource Card}" Margin="0,0,0,18" Visibility="Collapsed">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right" Content="取消" Style="{StaticResource SecondaryButton}" Click="CancelReplaceButton_Click" />
                                <TextBlock x:Name="ReplaceTitleText" Text="更换题目" Style="{StaticResource SectionTitle}" />
                            </DockPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="题型" FontWeight="SemiBold" />
                                    <ComboBox x:Name="ReplaceTypeComboBox" MinHeight="34" Margin="0,8,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="难度" FontWeight="SemiBold" />
                                    <ComboBox x:Name="ReplaceDifficultyComboBox" MinHeight="34" Margin="0,8,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="主题" FontWeight="SemiBold" />
                                    <ComboBox x:Name="ReplaceTopicComboBox" MinHeight="34" Margin="0,8,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="情景" FontWeight="SemiBold" />
                                    <ComboBox x:Name="ReplaceScenarioComboBox" MinHeight="34" Margin="0,8,0,0" />
                                </StackPanel>
                            </Grid>
                            <Button Content="按条件更换这道题" Width="150" HorizontalAlignment="Left" Margin="0,16,0,0" Style="{StaticResource PrimaryButton}" Click="ApplyReplaceButton_Click" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="18">
                                <TextBlock x:Name="PreviewTitleText" Text="作业预览" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
                                <TextBlock x:Name="PreviewMetaText" Text="选择范围和卷面结构后，点击“生成作业”。" Margin="0,8,0,18" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                                <ItemsControl x:Name="QuestionsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,18" Margin="0,0,0,18">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="True">
                                                        <Button DockPanel.Dock="Left" Content="换" Width="34" Height="30" Margin="0,0,10,0" Style="{StaticResource SecondaryButton}" ToolTip="更换这道题" Tag="{Binding}" Click="ReplaceQuestionButton_Click" />
                                                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    </DockPanel>
                                                    <TextBox Text="{Binding Stem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72" Margin="0,10,0,10" />
                                                    <ItemsControl ItemsSource="{Binding Options}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" TextWrapping="Wrap" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Text="答案与解析" FontWeight="SemiBold" Margin="0,6,0,6" />
                                                    <TextBox Text="{Binding Answer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="54" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </TabItem>

        <TabItem Header="题库管理">
            <DockPanel Margin="0,12,0,0">
                <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,18">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="下载题库模板" Style="{StaticResource SecondaryButton}" Click="ExportBankTemplateButton_Click" />
                            <Button Content="导入题库 CSV" Margin="10,0,0,0" Style="{StaticResource PrimaryButton}" Click="ImportBankButton_Click" />
                            <Button Content="保存云端" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" Click="SaveBankButton_Click" />
                            <Button Content="读取云端" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" Click="LoadBankButton_Click" />
                            <Button Content="清空云端" Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" Click="ClearBankButton_Click" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="题库管理" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="题库可通过 CSV 导入并保存云端，后续生成作业和更换题目会优先使用云端题库。字段需要包含题型、主题、考察方向、情景分类、难度、题干、选项、答案和解析。" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                            <TextBlock x:Name="BankStatusText" Margin="0,8,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Width="180">
                                <TextBlock Text="题型筛选" FontWeight="SemiBold" />
                                <ComboBox x:Name="BankTypeFilterComboBox" MinHeight="34" Margin="0,8,14,0" SelectionChanged="BankFilter_SelectionChanged" />
                            </StackPanel>
                            <StackPanel Width="200">
                                <TextBlock Text="主题筛选" FontWeight="SemiBold" />
                                <ComboBox x:Name="BankTopicFilterComboBox" MinHeight="34" Margin="0,8,14,0" SelectionChanged="BankFilter_SelectionChanged" />
                            </StackPanel>
                            <StackPanel Width="190">
                                <TextBlock Text="难度筛选" FontWeight="SemiBold" />
                                <ComboBox x:Name="BankDifficultyFilterComboBox" MinHeight="34" Margin="0,8,14,0" SelectionChanged="BankFilter_SelectionChanged" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <DataGrid x:Name="BankDataGrid" Margin="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="题型" Binding="{Binding Type}" Width="80" />
                                <DataGridTextColumn Header="主题" Binding="{Binding Topic}" Width="110" />
                                <DataGridTextColumn Header="考察方向" Binding="{Binding Direction}" Width="140" />
                                <DataGridTextColumn Header="情景分类" Binding="{Binding Scenario}" Width="140" />
                                <DataGridTextColumn Header="难度" Binding="{Binding Difficulty}" Width="90" />
                                <DataGridTextColumn Header="题干" Binding="{Binding Stem}" Width="*" />
                                <DataGridTextColumn Header="答案" Binding="{Binding Answer}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </DockPanel>
        </TabItem>
    </TabControl>
</UserControl>

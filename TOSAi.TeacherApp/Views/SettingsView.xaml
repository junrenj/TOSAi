<UserControl x:Class="TOSAi.TeacherApp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="880">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="AI 接入配置" Style="{StaticResource SectionTitle}" />

                <TextBlock Text="服务商" FontWeight="SemiBold" />
                <ComboBox x:Name="ProviderComboBox" SelectedIndex="0" Margin="0,8,0,16" MinHeight="34">
                    <ComboBoxItem Content="暂不接入（模拟分析）" />
                    <ComboBoxItem Content="OpenAI 兼容接口" />
                    <ComboBoxItem Content="本地模型服务" />
                    <ComboBoxItem Content="学校统一 AI 平台" />
                </ComboBox>

                <TextBlock Text="接口地址" FontWeight="SemiBold" />
                <TextBox x:Name="EndpointTextBox" Margin="0,8,0,16" MinHeight="34" Text="https://api.example.com/v1" />

                <TextBlock Text="模型名称" FontWeight="SemiBold" />
                <TextBox x:Name="ModelTextBox" Margin="0,8,0,16" MinHeight="34" Text="your-model-name" />

                <TextBlock Text="API Key" FontWeight="SemiBold" />
                <PasswordBox x:Name="ApiKeyPasswordBox" Margin="0,8,0,10" MinHeight="34" />
                <TextBlock Text="当前为原型阶段，API Key 会保存在本机用户数据目录的配置文件中。正式部署前建议改为 Windows 凭据管理器或加密存储。"
                           Foreground="{StaticResource WarningBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20" />

                <Button Content="保存设置" Width="110" HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click" />
                <TextBlock x:Name="StatusText" Margin="0,14,0,0" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="数据配置" Style="{StaticResource SectionTitle}" />
                <TextBlock Text="成绩数据保存位置" FontWeight="SemiBold" />
                <TextBox x:Name="ScoreDataPathTextBox" Margin="0,8,0,16" MinHeight="34" IsReadOnly="True" />
                <TextBlock Text="AI 配置保存位置" FontWeight="SemiBold" />
                <TextBox x:Name="AiSettingsPathTextBox" Margin="0,8,0,16" MinHeight="34" IsReadOnly="True" />
                <TextBlock Text="建议下一步将 AI 分析结果保存为报告记录，便于教师回看和复制。"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

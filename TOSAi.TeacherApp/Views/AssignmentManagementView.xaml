<UserControl x:Class="TOSAi.TeacherApp.Views.AssignmentManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="880">
    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="历史回顾"
                            Style="{StaticResource SecondaryButton}"
                            Click="HistoryButton_Click" />
                    <Button Content="下载本次报告"
                            Margin="10,0,0,0"
                            Style="{StaticResource PrimaryButton}"
                            Click="DownloadCurrentReportButton_Click" />
                    <Button Content="下载学生档案"
                            Margin="10,0,0,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="DownloadProfileReportButton_Click" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <StackPanel Width="230">
                        <TextBlock Text="学生" FontWeight="SemiBold" />
                        <ComboBox x:Name="StudentComboBox"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="StudentId"
                                  MinHeight="34"
                                  Margin="0,8,18,0"
                                  SelectionChanged="Filter_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Width="190">
                        <TextBlock Text="作业日期" FontWeight="SemiBold" />
                        <ComboBox x:Name="AssignmentDateComboBox"
                                  MinHeight="34"
                                  Margin="0,8,18,0"
                                  SelectionChanged="Filter_SelectionChanged" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,8"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="本次完成情况" Style="{StaticResource SectionTitle}" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,12,16">
                                <TextBlock Text="提交状态" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="SubmitStatusText" Text="-" FontSize="22" FontWeight="Bold" Margin="0,6,0,0" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="完成用时" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="DurationText" Text="-" FontSize="22" FontWeight="Bold" Margin="0,6,0,0" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="正确率" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="AccuracyText" Text="-" FontSize="22" FontWeight="Bold" Margin="0,6,0,0" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="薄弱模块" Style="{StaticResource MutedText}" />
                                <TextBlock x:Name="WeakModuleText" Text="-" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="知识模块掌握" Style="{StaticResource SectionTitle}" />
                        <ItemsControl x:Name="ModuleItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="24"
                                                Height="24"
                                                CornerRadius="12"
                                                Background="{Binding StatusBrush}"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Icon}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding ModuleName}" FontWeight="SemiBold" />
                                            <ProgressBar Value="{Binding MasteryRate}" Maximum="100" Height="8" Margin="0,6,12,0" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding RateText}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="DetailTitleText" Text="题目完成明细" Style="{StaticResource SectionTitle}" />
                        <TextBlock x:Name="DetailSubtitleText"
                                   Text="选择学生和作业日期后查看。"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,14"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TabControl Grid.Row="1">
                        <TabItem Header="本次作业">
                            <DataGrid x:Name="QuestionDataGrid" Margin="0,12,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="题号" Binding="{Binding Number}" Width="60" />
                                    <DataGridTextColumn Header="题型" Binding="{Binding Type}" Width="80" />
                                    <DataGridTextColumn Header="主题" Binding="{Binding Topic}" Width="120" />
                                    <DataGridTextColumn Header="情景" Binding="{Binding Scenario}" Width="130" />
                                    <DataGridTextColumn Header="难度" Binding="{Binding Difficulty}" Width="90" />
                                    <DataGridTextColumn Header="结果" Binding="{Binding ResultText}" Width="80" />
                                    <DataGridTextColumn Header="用时" Binding="{Binding TimeSpentText}" Width="70" />
                                    <DataGridTextColumn Header="反馈" Binding="{Binding Feedback}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="历史档案">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="考试与作业趋势" FontWeight="SemiBold" Margin="0,0,0,12" />
                                    <ItemsControl x:Name="HistoryItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,14">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="108" />
                                                        <ColumnDefinition Width="84" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="48" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DateText}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Category}" Foreground="{StaticResource AccentBrush}" />
                                                    <ProgressBar Grid.Column="2" Value="{Binding ScoreRate}" Maximum="100" Height="12" Margin="0,4,14,0" />
                                                    <TextBlock Grid.Column="3" Text="{Binding RateText}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Background="{StaticResource SoftSurfaceBrush}" CornerRadius="8" Padding="14" Margin="0,18,0,0">
                                        <TextBlock x:Name="ProfileSummaryText"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
